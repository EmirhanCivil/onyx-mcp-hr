# =====================================================================
# 1. ⚠ EN ÖNEMLİ AYAR — KENDİ DATA KLASÖRÜNÜ BURADA BELİRT
# =====================================================================
# Container'a mount edilecek host dizini. Aşağıdaki yapıyı içermeli:
#   <data-klasörünüz>/
#     ├── uploads/cv/      → CV dosyaları (.pdf, .docx, .txt)
#     ├── uploads/excel/   → Aday Excel'leri (.xlsx, .csv, .ods, …)
#     └── uploads/survey/  → Anket dosyaları
# (outputs/ ve processed/ klasörleri otomatik oluşturulur — orada chart/rapor
# çıktıları biriktiği için yedeklemeye değer.)
#
# Linux/Mac örneği:  HR_DATA_DIR=/home/user/hr-data
# Windows örneği:    HR_DATA_DIR=D:/HR-Data
# Test için repo içi (boş): HR_DATA_DIR=./data
HR_DATA_DIR=./data

# =====================================================================
# 2. ⚠ ONYX UI ERİŞİM URL'i — chart/rapor linkleri için ŞART
# =====================================================================
# Onyx UI tarayıcı tarafında çalışır. Chart/rapor markdown linkleri bu URL'den
# servis edilir. Browser bu URL'e ulaşabilmeli, yoksa görseller broken görünür.
#
# Senaryolar (host'ta nginx port 8018):
#   - Tek makinede test:                http://localhost:8018
#   - Sunucu IP ile erişim:             http://192.168.1.50:8018
#   - DNS/domain ile erişim:            http://onyx.example.com:8018
#   - HTTPS reverse proxy arkası:       https://onyx.example.com/files
PUBLIC_FILES_BASE_URL=http://localhost:8018

# =====================================================================
# 3. MCP server transport (genelde dokunma)
# =====================================================================
MCP_HOST=0.0.0.0
MCP_PORT=8005
MCP_TRANSPORT=http
MCP_PATH=/mcp

# =====================================================================
# 3. Container içi path'ler — DEĞİŞTİRMEYİN
# =====================================================================
DATA_DIR=/app/data
UPLOAD_DIR=/app/data/uploads
CV_UPLOAD_DIR=/app/data/uploads/cv
EXCEL_UPLOAD_DIR=/app/data/uploads/excel
SURVEY_UPLOAD_DIR=/app/data/uploads/survey
PROCESSED_DIR=/app/data/processed
OUTPUT_DIR=/app/data/outputs
CHART_DIR=/app/data/outputs/charts
REPORT_DIR=/app/data/outputs/reports
EXPORT_DIR=/app/data/outputs/exports
LOG_DIR=/app/logs

# =====================================================================
# 4. Davranış ayarları
# =====================================================================
LOG_LEVEL=INFO
AUTO_LOAD_ENABLED=false
AUTO_EXCEL_PATH=
AUTO_SCAN_UPLOADS_ENABLED=true
DEFAULT_MIN_GROUP_SIZE=5
MAX_PREVIEW_ROWS=50
LARGE_FILE_ROW_THRESHOLD=100000
